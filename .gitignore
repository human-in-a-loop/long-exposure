*.sqlite
*.sqlite3

# Logs (any pattern, anywhere in the repo)
*.log
*.log.*

# Health / event streams
health_events.jsonl

# Signal files
*.stop
*.clear
*.guide
*.guidance
*.graceful-stop

# Per-clone instance directories
instance-*/
fork-*/
clone-*/

